# Copia este archivo como .env para desarrollo local

# PostgreSQL connection string (Railway te da esta URL)
DATABASE_URL=postgresql://usuario:password@localhost:5432/therian

# Google OAuth Client ID (de Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# Secreto para firmar JWT (usa un string largo y aleatorio)
JWT_SECRET=cambia_esto_por_un_secreto_seguro_y_largo

# UID del usuario admin (su Google sub ID, se ve en la tabla users)
ADMIN_UID=

# URL del frontend (para CORS)
FRONTEND_URL=https://therianworld.netlify.app

# Puerto del servidor
PORT=4000
