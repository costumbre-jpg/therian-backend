# Copy this file as .env for local development

# PostgreSQL connection string (Railway gives you this URL)
DATABASE_URL=postgresql://user:password@localhost:5432/therian

# Google OAuth Client ID (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Secret for signing JWT (use a long random string)
JWT_SECRET=change_this_to_a_secure_and_long_secret

# UID of the admin user (their Google sub ID, visible in the users table)
ADMIN_UID=

# Frontend URL (for CORS)
FRONTEND_URL=https://therianworld.netlify.app

# Server port
PORT=4000

# Web3Forms API key (for contact form and report emails)
WEB3FORMS_KEY=your-web3forms-access-key

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
